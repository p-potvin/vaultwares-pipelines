# Example Nginx reverse-proxy config for Brume 2 (OpenWrt).
#
# Goal:
# - Brume terminates TLS for api.vaultwares.com
# - Brume rate-limits and becomes the choke-point for abuse controls
# - Brume proxies to the API host on LAN: http://10.0.0.24:9001
# - Brume injects X-VW-Gateway-Secret so the API can reject direct/bypass traffic
#
# You still need:
# - real cert/key paths (via luci-app-acme or your preferred ACME client)
# - a DNS A record for api.vaultwares.com pointing to your WAN IP
# - port forwards 80/443 -> Brume 2
#
# Replace: <GATEWAY_SHARED_SECRET> with the same value used in the API `.env`.

limit_req_zone $binary_remote_addr zone=vaultwares_api:10m rate=5r/s;
limit_req_zone $binary_remote_addr zone=vaultwares_login:10m rate=1r/s;

# Treat Tailscale clients as trusted for gateway filtering (supports scripts without Origin header).
geo $vw_is_tailscale {
    default 0;
    100.64.0.0/10 1;
    fd7a:115c:a1e0::/48 1;
}

# Allowlist Vercel app origins (add/remove as needed).
# Use stable alias domains (e.g. https://vault-flows.vercel.app), not preview URLs.
map $http_origin $vw_origin_ok {
    default 0;
    "https://vault-flows.vercel.app" 1;
    # "https://dispatch-wares-frontend.vercel.app" 1;
    # "https://vaultwares-pipelines-frontend.vercel.app" 1;
    # "https://cultural-rhythm.vercel.app" 1;
    # "https://glass-ui-preview.vercel.app" 1;
}

server {
    listen 80;
    server_name api.vaultwares.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name api.vaultwares.com;

    # --- TLS certs (example paths) ---
    # luci-app-acme / acme.sh commonly stores files under:
    # - /etc/acme/<domain>/fullchain.cer
    # - /etc/acme/<domain>/<domain>.key
    #
    # Some setups use an "_ecc" suffix directory for ECDSA keys:
    # - /etc/acme/<domain>_ecc/<domain>.cer
    # - /etc/acme/<domain>_ecc/<domain>.key
    #
    # Set these to match your Brume 2 box:
    # ssl_certificate     /etc/acme/api.vaultwares.com/fullchain.cer;
    # ssl_certificate_key /etc/acme/api.vaultwares.com/api.vaultwares.com.key;

    # Strict HTTPS (enable HSTS once stable)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    # Large uploads (LoRA / checkpoints). Adjust as needed.
    client_max_body_size 10g;

    # Rate limit (tune as needed)
    limit_req zone=vaultwares_api burst=40 nodelay;

    # Stricter throttling for login to slow brute force attempts
    location = /auth/login {
        limit_req zone=vaultwares_login burst=5 nodelay;

        # Public internet must have an allowed Origin. Tailscale can omit Origin.
        if ($vw_is_tailscale = 0) {
            if ($http_origin = "") { return 403; }
            if ($vw_origin_ok = 0) { return 403; }
        }

        proxy_pass http://10.0.0.24:9001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-VW-Gateway-Secret "<GATEWAY_SHARED_SECRET>";

        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
        proxy_request_buffering off;
        proxy_buffering off;
    }

    location / {
        # Public internet must have an allowed Origin. Tailscale can omit Origin.
        # Later: replace the 403 with a redirect to your Identity Manager registration page.
        if ($vw_is_tailscale = 0) {
            if ($http_origin = "") { return 403; }
            if ($vw_origin_ok = 0) { return 403; }
        }

        proxy_pass http://10.0.0.24:9001;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;

        # Brume gateway secret injection (API requires it for public clients)
        proxy_set_header X-VW-Gateway-Secret "<GATEWAY_SHARED_SECRET>";

        # Good defaults for long-running responses (still prefer async jobs + polling)
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;

        # Stream large uploads to the API host
        proxy_request_buffering off;
        proxy_buffering off;
    }
}
